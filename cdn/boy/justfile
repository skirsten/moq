# List all of the available commands.
default:
  just --list

# Pin to the latest moq-boy release tag (or a specific tag)
pin tag="":
	#!/usr/bin/env bash
	set -euo pipefail
	TAG="{{tag}}"
	if [ -z "$TAG" ]; then
		TAG=$(git ls-remote --tags --sort=-v:refname https://github.com/moq-dev/moq.git 'refs/tags/moq-boy-v*' | grep -v '\^{}' | head -1 | sed 's|.*/||')
	fi
	if [ -z "$TAG" ]; then
		echo "error: no moq-boy tags found" >&2
		exit 1
	fi
	echo "Pinning to $TAG..."
	nix flake lock --override-input moq "github:moq-dev/moq/$TAG" --update-input moq

# Get the hostname for the boy instance
host:
	#!/usr/bin/env bash
	DOMAIN=$(cd .. && tofu output -raw domain)
	echo "boy.$DOMAIN"

# Deploy boy instance
deploy:
	#!/usr/bin/env bash
	set -euo pipefail
	HOST=$(just host)
	echo "Deploying to $HOST..."

	echo "  Copying flake files to /var/lib/moq"
	rsync -az flake.nix flake.lock root@$HOST:/var/lib/moq/

	echo "  Copying secrets to /var/lib/moq"
	rsync -az ../secrets/ root@$HOST:/var/lib/moq/
	ssh root@$HOST "find /var/lib/moq -type d -exec chmod 755 {} + && find /var/lib/moq -type f -exec chmod 644 {} + && chmod 600 /var/lib/moq/*.jwt"

	echo "  Copying systemd units to /etc/systemd/system/..."
	rsync -az --exclude='.gitignore' gen/ root@$HOST:/etc/systemd/system/
	rsync -az ../common/vacuum.service ../common/vacuum.timer ../common/monitor.sh root@$HOST:/etc/systemd/system/
	rsync -az --exclude='.gitignore' ../common/gen/ root@$HOST:/etc/systemd/system/

	echo "  Building and caching packages..."
	ssh root@$HOST "cd /var/lib/moq && nix build -o pkg"

	echo "  Enabling and starting services..."
	ssh root@$HOST "\
		systemctl daemon-reload && \
		systemctl enable vacuum.timer && \
		systemctl enable monitor.service && \
		systemctl start vacuum.timer && \
		systemctl restart monitor.service && \
		systemctl enable boy-prepare.service && \
		systemctl start boy-prepare.service && \
		systemctl enable boy-big2small.service boy-dangan.service boy-opossum.service boy-capybara.service boy-fofk.service boy-gb-run.service && \
		systemctl restart boy-big2small.service boy-dangan.service boy-opossum.service boy-capybara.service boy-fofk.service boy-gb-run.service"

# Check status of all boy services
status:
	#!/usr/bin/env bash
	HOST=$(just host)
	echo "=== $HOST ==="
	ssh root@$HOST "systemctl list-units 'boy-*' --no-pager"

# SSH into boy instance
ssh:
	#!/usr/bin/env bash
	HOST=$(just host)
	ssh root@$HOST

# Restart all boy services
restart:
	#!/usr/bin/env bash
	HOST=$(just host)
	echo "=== $HOST ==="
	ssh root@$HOST "systemctl restart boy-big2small boy-dangan boy-opossum boy-capybara boy-fofk boy-gb-run --no-pager"

# View logs from a specific game (default: all)
logs game="":
	#!/usr/bin/env bash
	HOST=$(just host)
	if [ -z "{{game}}" ]; then
		ssh root@$HOST "journalctl -u 'boy-*' -f"
	else
		ssh root@$HOST "journalctl -u boy-{{game}} -f"
	fi

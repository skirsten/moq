# List all of the available commands.
default:
  just --list

# Pin to the latest moq-cli release tag (or a specific tag)
pin tag="":
	#!/usr/bin/env bash
	set -euo pipefail
	TAG="{{tag}}"
	if [ -z "$TAG" ]; then
		TAG=$(git ls-remote --tags --sort=-v:refname https://github.com/moq-dev/moq.git 'refs/tags/moq-cli-v*' | grep -v '\^{}' | head -1 | sed 's|.*/||')
	fi
	if [ -z "$TAG" ]; then
		echo "error: no moq-cli tags found" >&2
		exit 1
	fi
	echo "Pinning to $TAG..."
	nix flake update
	nix flake lock --override-input moq "github:moq-dev/moq/$TAG"

# Get the hostname for the publisher
host:
	#!/usr/bin/env bash
	DOMAIN=$(cd .. && tofu output -raw domain)
	echo "pub.$DOMAIN"

# Deploy publisher
deploy:
	#!/usr/bin/env bash
	set -euo pipefail
	HOST=$(just host)
	echo "Deploying to $HOST..."

	echo "  Copying flake files to /var/lib/moq"
	rsync -az flake.nix flake.lock root@$HOST:/var/lib/moq/

	echo "  Copying secrets to /var/lib/moq"
	rsync -az ../secrets/ root@$HOST:/var/lib/moq/
	ssh root@$HOST "chmod -R 755 /var/lib/moq && chmod 600 /var/lib/moq/*.jwt"

	echo "  Copying systemd units to /etc/systemd/system/..."
	rsync -az demo-bbb-prepare.service root@$HOST:/etc/systemd/system/
	rsync -az --exclude='.gitignore' gen/ root@$HOST:/etc/systemd/system/
	rsync -az ../common/vacuum.service ../common/vacuum.timer ../common/memory-alert.sh root@$HOST:/etc/systemd/system/
	rsync -az --exclude='.gitignore' ../common/gen/ root@$HOST:/etc/systemd/system/

	echo "  Building and caching packages..."
	ssh root@$HOST "cd /var/lib/moq && nix build -o pkg"

	echo "  Enabling and starting services..."
	ssh root@$HOST "\
		systemctl daemon-reload && \
		systemctl enable demo-bbb-prepare.service && \
		systemctl enable demo-bbb.service && \
		systemctl enable vacuum.timer && \
		systemctl enable memory-alert.service && \
		systemctl start demo-bbb-prepare.service && \
		systemctl start vacuum.timer && \
		systemctl restart memory-alert.service && \
		systemctl restart demo-bbb.service"

# Check status of publisher
status:
	#!/usr/bin/env bash
	HOST=$(just host)
	echo "=== $HOST ==="
	ssh root@$HOST "systemctl status demo-bbb --no-pager"

# SSH into publisher
ssh:
	#!/usr/bin/env bash
	HOST=$(just host)
	ssh root@$HOST

# View logs from publisher
logs:
	#!/usr/bin/env bash
	HOST=$(just host)
	ssh root@$HOST "journalctl -u demo-bbb -f"

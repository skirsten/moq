{
	"name": "@moq/boy",
	"type": "module",
	"version": "0.2.10",
	"jsr": false,
	"description": "MoQ Boy - Crowd-controlled Game Boy streaming via MoQ",
	"license": "(MIT OR Apache-2.0)",
	"repository": {
		"type": "git",
		"url": "https://github.com/moq-dev/moq",
		"directory": "js/moq-boy"
	},
	"exports": {
		".": "./src/index.ts",
		"./element": "./src/element.tsx"
	},
	"sideEffects": [
		"./src/element.tsx"
	],
	"scripts": {
		"build": "rimraf dist && vite build && tsc && bun ../common/package.ts",
		"check": "tsc --noEmit",
		"release": "bun ../common/release.ts"
	},
	"dependencies": {
		"@moq/json": "workspace:^",
		"@moq/net": "workspace:^",
		"@moq/watch": "workspace:^",
		"@moq/signals": "workspace:^",
		"zod": "^4.4.3"
	},
	"//devDependencies": "These are only needed for local development with workspace packages. They are NOT needed when using the published npm packages.",
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"esbuild": "^0.28.1",
		"rimraf": "^6.1.3",
		"solid-js": "^1.9.13",
		"typescript": "7.0.1-rc",
		"vite": "^8.0.16",
		"vite-plugin-solid": "^2.11.12"
	}
}

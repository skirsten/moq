{
	"name": "@moq/watch",
	"type": "module",
	"version": "0.2.18",
	"jsr": false,
	"description": "Watch Media over QUIC broadcasts",
	"license": "(MIT OR Apache-2.0)",
	"repository": "github:moq-dev/moq",
	"exports": {
		".": "./src/index.ts",
		"./element": "./src/element.ts",
		"./ui": "./src/ui/element.ts",
		"./support": "./src/support/index.ts",
		"./support/element": "./src/support/element.ts"
	},
	"sideEffects": [
		"./src/element.ts",
		"./src/ui/element.ts",
		"./src/support/element.ts"
	],
	"scripts": {
		"build": "rimraf dist && vite build && tsc && bun ../common/package.ts",
		"check": "tsc --noEmit",
		"test": "bun test --only-failures",
		"release": "bun ../common/release.ts"
	},
	"dependencies": {
		"@moq/hang": "workspace:^",
		"@moq/json": "workspace:^",
		"@moq/net": "workspace:^",
		"@moq/msf": "workspace:^",
		"@moq/signals": "workspace:^"
	},
	"devDependencies": {
		"@types/audioworklet": "^0.0.100",
		"@types/bun": "^1.3.14",
		"@typescript/lib-dom": "npm:@types/web@^0.0.350",
		"esbuild": "^0.28.1",
		"rimraf": "^6.1.3",
		"typescript": "7.0.1-rc",
		"vite": "^8.0.16"
	}
}

{
	"name": "@moq/publish",
	"type": "module",
	"version": "0.2.7",
	"description": "Publish Media over QUIC broadcasts",
	"license": "(MIT OR Apache-2.0)",
	"repository": "github:moq-dev/moq",
	"exports": {
		".": "./src/index.ts",
		"./element": "./src/element.ts",
		"./ui": "./src/ui/element.ts",
		"./support": "./src/support/index.ts",
		"./support/element": "./src/support/element.ts"
	},
	"sideEffects": [
		"./src/element.ts",
		"./src/ui/element.ts",
		"./src/support/element.ts"
	],
	"scripts": {
		"build": "rimraf dist && vite build && tsc && bun ../common/package.ts",
		"check": "tsc --noEmit",
		"release": "bun ../common/release.ts"
	},
	"dependencies": {
		"@moq/hang": "workspace:^",
		"@moq/net": "workspace:^",
		"@moq/signals": "workspace:^"
	},
	"devDependencies": {
		"@types/audioworklet": "^0.0.77",
		"@typescript/lib-dom": "npm:@types/web@^0.0.241",
		"esbuild": "^0.27.0",
		"rimraf": "^6.0.1",
		"typescript": "^6.0.0",
		"vite": "^7.3.1"
	}
}

# Copy to .env.local (gitignored) and fill in. Bun loads .env / .env.local automatically
# when you run `bun run.ts`. Shell env still wins over file vars.

# Sauce Labs (default provider)
SAUCE_USERNAME=
SAUCE_ACCESS_KEY=

# BrowserStack (when a target uses provider: browserstack)
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=

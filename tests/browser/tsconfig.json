{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": ["run.ts"]
}
